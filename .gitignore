# Root .gitignore — Covers both client and server
# ─────────────────────────────────────────────────

# Dependencies
node_modules/
**/node_modules/

# Build outputs
client/dist/
client/build/

# Environment files — NEVER commit these
.env
.env.local
.env.production
.env.development
**/.env
**/.env.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Vite cache
.vite/
