# ── PRODUCTION ENVIRONMENT VARIABLES ──────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Set these in your Render dashboard under Environment → Environment Variables.

PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/quickcommerce?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_string_at_least_64_chars
NODE_ENV=production

# Your deployed frontend URL (no trailing slash)
# e.g. https://your-app.vercel.app
ALLOWED_ORIGINS=https://your-app.vercel.app
